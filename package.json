{
  "name": "annotation",
  "publisher": "SWUST-WEBLAB-LMH",
  "displayName": "JSDoc Annotation",
  "description": "Generate configurable JSDoc and TSDoc comments for JavaScript and TypeScript with AST-first parsing",
  "version": "1.0.7",
  "icon": "./logo.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:addAnnotation",
    "onCommand:addAnnotations",
    "onCommand:openConfigConsole",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "addAnnotation",
        "title": "Annotation: Add Annotation"
      },
      {
        "command": "openConfigConsole",
        "title": "Annotation: Open Settings"
      },
      {
        "command": "addAnnotations",
        "title": "Annotation: Add Annotations"
      }
    ],
    "keybindings": [
      {
        "command": "addAnnotation",
        "key": "alt+\\"
      },
      {
        "command": "openConfigConsole",
        "key": "alt+shift+\\"
      },
      {
        "command": "addAnnotations",
        "key": "ctrl+alt+\\"
      }
    ],
    "configuration": {
      "title": "Annotation",
      "properties": {
        "annotation.behavior": {
          "type": "object",
          "default": {
            "mode": "insert"
          },
          "description": "Generation behavior. mode: insert | replace | skip."
        },
        "annotation.global": {
          "type": "object",
          "default": {
            "authorInfo": "",
            "versionInfo": "",
            "licenseInfo": "",
            "copyrightInfo": ""
          },
          "description": "Global values shared by generated annotations."
        },
        "annotation.class.tags": {
          "type": "object",
          "default": {
            "classTag": true,
            "abstractTag": true,
            "extendsTag": true,
            "implementsTag": true,
            "authorTag": false,
            "aliasTag": false,
            "versionTag": false,
            "nameTag": true,
            "descriptionTag": true,
            "seeTag": false,
            "exampleTag": false,
            "templateTag": true
          },
          "description": "Class annotation tag switches."
        },
        "annotation.method.tags": {
          "type": "object",
          "default": {
            "asyncTag": true,
            "functionTag": true,
            "constructorTag": true,
            "throwsTag": true,
            "paramsTag": true,
            "returnsTag": true,
            "staticTag": true,
            "accessTag": true,
            "authorTag": false,
            "aliasTag": false,
            "versionTag": false,
            "nameTag": true,
            "descriptionTag": true,
            "seeTag": false,
            "exampleTag": false,
            "templateTag": true
          },
          "description": "Method and function annotation tag switches."
        },
        "annotation.property.tags": {
          "type": "object",
          "default": {
            "propertyTag": true,
            "typeTag": true,
            "staticTag": true,
            "defaultTag": true,
            "aliasTag": true,
            "nameTag": true,
            "descriptionTag": true,
            "seeTag": false,
            "exampleTag": false,
            "templateTag": true
          },
          "description": "Property annotation tag switches."
        },
        "annotation.interface.tags": {
          "type": "object",
          "default": {
            "interfaceTag": true,
            "extendsTag": true,
            "authorTag": false,
            "versionTag": false,
            "templateTag": true,
            "aliasTag": false,
            "nameTag": true,
            "descriptionTag": true,
            "seeTag": false,
            "exampleTag": false
          },
          "description": "Interface annotation tag switches."
        },
        "annotation.enum.tags": {
          "type": "object",
          "default": {
            "enumTag": true,
            "aliasTag": false,
            "nameTag": true,
            "descriptionTag": true,
            "seeTag": false,
            "exampleTag": false
          },
          "description": "Enum annotation tag switches."
        },
        "annotation.typedef.tags": {
          "type": "object",
          "default": {
            "typedefTag": true,
            "typeTag": true,
            "templateTag": true,
            "aliasTag": true,
            "nameTag": true,
            "descriptionTag": true,
            "seeTag": true,
            "exampleTag": true
          },
          "description": "Type alias annotation tag switches."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.8",
    "@types/node": "20.x",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.11.1",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "ts-morph": "^24.0.0"
  }
}
